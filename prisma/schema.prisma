generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id         String        @id @default(cuid())
  slug       String        @unique
  title      String
  summary    String
  status     ProjectStatus @default(DRAFT)
  tags       String
  repository String?
  demoUrl    String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}
